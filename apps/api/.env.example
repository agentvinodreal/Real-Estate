# Copy to .env and fill in.
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Neon Postgres) example:
# DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/carry?sslmode=require"

PORT=4000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Clerk secret key — verifies session tokens for protected (write) routes.
# Get this from dashboard.clerk.com → API Keys. Same Clerk app as apps/admin
# and apps/web's VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY="sk_test_..."

# OpenRouter Configuration (Optional - fallback to Gemini or OpenAI)
# Get a key from https://openrouter.ai/settings/keys — without this set (or
# GEMINI_API_KEY / OPENAI_API_KEY), Home Designer visualizations fall back to
# a static mock placeholder image regardless of input.
OPENROUTER_API_KEY="sk-or-v1-..."
# Default image model to use. See https://openrouter.ai/models?output_modalities=image
# for current options (e.g. google/gemini-2.5-flash-image, black-forest-labs/flux.2-pro).
OPENROUTER_IMAGE_MODEL="google/gemini-2.5-flash-image"

