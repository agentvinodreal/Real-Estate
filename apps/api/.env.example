# Copy to .env and fill in.
# Since schema.prisma uses the "postgresql" provider, both development and production
# environments must use PostgreSQL.

# Local Dev Database URL:
DATABASE_URL="postgresql://neondb_owner:npg_xxx@ep-xxx.us-east-1.aws.neon.tech/carry_dev?sslmode=require"

# Production Database URL:
# DATABASE_URL="postgresql://neondb_owner:npg_xxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

PORT=4000

# Shared secret for the Field Ops publish webhook (POST /api/v1/sync).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# The identical value must be configured in the Field Ops project so its
# "Publish" button can authenticate to this API. Without it, /api/v1/sync
# returns 503 and publishing will not reach the website.
SYNC_SECRET="..."
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# Clerk Secret Key — verifies session tokens.
# Use Clerk Development Instance keys (starts with sk_test_) for local dev.
# Use Clerk Production Instance keys (starts with sk_live_) for production.
CLERK_SECRET_KEY="sk_test_..."

# Cloudinary credentials.
# Local dev should use the development Cloudinary cloud name.
# Production resolves to the production account ('piwpzbke' for listing photos).
CLOUDINARY_CLOUD_NAME="pvrehhhs"
CLOUDINARY_API_KEY="xxx"
CLOUDINARY_API_SECRET="xxx"

# OpenRouter Configuration (Optional - fallback to Gemini or OpenAI)
# Get a key from https://openrouter.ai/settings/keys — without this set (or
# GEMINI_API_KEY / OPENAI_API_KEY), Home Designer visualizations fall back to
# a static mock placeholder image regardless of input.
OPENROUTER_API_KEY="sk-or-v1-..."
# Default image model to use. See https://openrouter.ai/models?output_modalities=image
# for current options (e.g. google/gemini-2.5-flash-image, black-forest-labs/flux.2-pro).
OPENROUTER_IMAGE_MODEL="google/gemini-2.5-flash-image"
OPENROUTER_TEXT_MODEL="google/gemini-2.5-flash"

# Vercel AI Gateway Configuration (Optional - for local dev/testing with free credits)
# Obtain keys and endpoint URL from Vercel dashboard AI section.
# AI_GATEWAY_API_KEY="your-vercel-ai-gateway-api-key"
# AI_GATEWAY_URL="https://gateway.ai.vercel.com/v1/projects/<project-id>/gateways/<gateway-id>"
# Optional custom models for Vercel AI Gateway
# AI_GATEWAY_IMAGE_MODEL="dall-e-3"
# AI_GATEWAY_TEXT_MODEL="gpt-4o-mini"

