# Copy to .env and fill in.
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Neon Postgres) example:
# DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/carry?sslmode=require"

PORT=4000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Clerk secret key — verifies session tokens for protected (write) routes.
# Get this from dashboard.clerk.com → API Keys. Same Clerk app as apps/admin
# and apps/web's VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY="sk_test_..."
