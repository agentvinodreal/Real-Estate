# Copy to .env and fill in.
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Neon Postgres) example:
# DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/carry?sslmode=require"

PORT=4000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
ADMIN_API_KEY="change-me"

# Firebase Admin (production auth) — service account, used by src/lib/auth.ts
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""
