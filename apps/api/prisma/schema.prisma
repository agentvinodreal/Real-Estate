// Carry Construction data model (Unified PostgreSQL version)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Agent (from Field Ops) ─────────────────────────────────────────────
model Agent {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  name        String
  email       String   @unique
  phone       String?
  age         Int?
  status      String   @default("active") // "active" | "revoked"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties Property[]
  projects   ConstructionProject[]
  labour     Labour[]
  shops      Shop[]

  @@index([clerkUserId])
  @@map("agents")
}

// ── Property ───────────────────────────────────────────────────────────
model Property {
  id                 String   @id @default(cuid())
  title              String
  propertyType       String
  listingType        String
  bhk                Int?
  priceInr           Int
  priceLabel         String
  areaSqft           Int
  carpetAreaSqft     Int?
  builtupAreaSqft    Int?
  locality           String
  city               String
  address            String?
  reraNumber         String?
  status             String
  furnishing         String?
  description        String?
  images             String[] @default([])
  floorPlanUrl       String?
  lat                Float?
  lng                Float?
  reviewStatus       String   @default("pending")
  agentId            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  availableFrom      String?
  camCharges         Int?
  leaseDuration      Int?
  lockInPeriod       Int?
  maintenanceCharges Int?
  petFriendly        Boolean?
  plotAllowedUse     String?
  preferredTenant    String?
  securityDeposit    Int?
  published          Boolean  @default(false)
  slug               String?  @unique
  featured           Boolean  @default(false)
  videoUrl           String?
  amenities          String[] @default([])
  agent              Agent?   @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([reviewStatus])
  @@index([city, listingType, propertyType])
  @@map("properties")
}

// ── ConstructionProject ────────────────────────────────────────────────
model ConstructionProject {
  id             String   @id @default(cuid())
  title          String
  category       String
  location       String
  areaSqft       Int?
  durationMonths Int?
  packageTier    String?
  description    String?
  beforeImages   String[] @default([])
  afterImages    String[] @default([])
  stageImages    String[] @default([])
  reviewStatus   String   @default("pending")
  agentId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  published      Boolean  @default(false)
  slug           String?  @unique
  agent          Agent?   @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([reviewStatus])
  @@index([category])
  @@map("construction_projects")
}

// ── Labour ─────────────────────────────────────────────────────────────
model Labour {
  id              String   @id @default(cuid())
  fullName        String
  age             Int
  gender          String
  skillLevel      String
  skillType       String?
  phone           String
  profilePhotoUrl String?
  houseNo         String?
  street          String?
  locality        String?
  city            String?
  pincode         String?
  reviewStatus    String   @default("pending")
  agentId         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  minimumWage     Int?
  agent           Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([reviewStatus])
  @@index([city, skillLevel])
  @@map("labour")
}

// ── Shop ────────────────────────────────────────────────────────────────
model Shop {
  id           String   @id @default(cuid())
  shopName     String
  shopType     String
  keeperName   String
  keeperPhone  String
  address      String?
  lat          Float?
  lng          Float?
  reviewStatus String   @default("pending")
  agentId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  images       String[] @default([])
  agent        Agent    @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@index([reviewStatus])
  @@index([shopType])
  @@map("shops")
}

// ── Lead (from Real Estate) ────────────────────────────────────────────
model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  sourcePage      String?
  propertyId      String?
  projectId       String?
  message         String?
  status          String   @default("new") // new | contacted | visit | closed
  marketplaceType String?  // "Material" | "Equipment" | "ServiceProvider"
  itemId          String?  // References specific item
  itemQty         Int?     // Quantity (number of bags, rental days, etc.)
  createdAt       DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// ── Testimonial (from Real Estate) ─────────────────────────────────────
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String?
  rating    Int      @default(5)
  quote     String
  avatarUrl String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([published, createdAt])
  @@map("testimonials")
}

// ── Material (from Real Estate) ────────────────────────────────────────
model Material {
  id          String   @id @default(cuid())
  name        String
  category    String   // e.g. "Steel", "Cement", "Flooring", "Glass"
  brand       String   // e.g. "Tata Tiscon", "Ultratech"
  description String?
  imageUrl    String?
  price       Int?     // Price in INR (optional)
  unit        String?  // Unit of price (e.g. "per bag", "per ton")
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("materials")
}

// ── BlogPost (from Real Estate) ────────────────────────────────────────
model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  excerpt         String
  coverImage      String?
  body            String
  metaTitle       String?
  metaDescription String?
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([published, createdAt])
  @@map("blog_posts")
}

// ── ServiceProvider (from Real Estate) ─────────────────────────────────
model ServiceProvider {
  id              String   @id @default(cuid())
  name            String
  role            String   // "Contractor" | "Civil Engineer" | "Architect" | "Labour"
  phone           String
  email           String?
  city            String
  locality        String?
  experienceYears Int?
  rating          Float?   @default(5.0)
  profilePhotoUrl String?
  description     String?
  specialties     String[] @default([])
  minimumRate     Int?     // rate in INR
  rateUnit        String?  // "per day", "per sqft", "per project"
  reviewStatus    String   @default("approved")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([role])
  @@index([city])
  @@map("service_providers")
}

// ── EquipmentRental (from Real Estate) ─────────────────────────────────
model EquipmentRental {
  id           String   @id @default(cuid())
  name         String   // e.g. "JCB Excavator 3DX", "Concrete Mixer Machine"
  category     String   // e.g. "Earthmoving", "Concrete", "Scaffolding"
  rentPerDay   Int      // Rent in INR per day
  imageUrl     String?
  description  String?
  specs        String[] @default([])
  available    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@map("equipment_rentals")
}

// ── FloorPlanGeneration (from Real Estate) ─────────────────────────────────────
model FloorPlanGeneration {
  id           String   @id @default(cuid())
  userId       String   // Clerk User ID (sub)
  inputs       Json     // Store user inputs { bhk, areaSqft, style, facing, extras, floor }
  promptUsed   String   @db.Text
  imageUrl     String   // Cloudinary CDN URL
  cloudinaryId String?  // Cloudinary public_id (for deletion)
  aiModel      String   // e.g., "gemini" | "openai"
  costUsd      Decimal? @db.Decimal(8, 6)
  status       String   @default("completed") // "pending" | "completed" | "failed"
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@map("floor_plan_generations")
}

